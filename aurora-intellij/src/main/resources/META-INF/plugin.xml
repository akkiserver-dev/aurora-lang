<idea-plugin>
    <id>aurora.intellij</id>
    <name>Aurora Language Support</name>
    <vendor>Aurora</vendor>

    <description><![CDATA[
        Aurora language support for IntelliJ IDEA.
        Provides syntax highlighting via a built-in lexer and full IDE features
        (diagnostics, hover, go-to-definition, completion, semantic highlighting)
        via the bundled Aurora Language Server.
    ]]></description>

    <idea-version since-build="243" until-build="243.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File type recognition -->
        <fileType
                name="Aurora Source"
                language="aurora"
                implementationClass="aurora.intellij.AuroraLangFileType"
                extensions="ar"/>

        <!-- Lexer-based parser definition (required for syntax highlighting) -->
        <lang.parserDefinition
                language="aurora"
                implementationClass="aurora.intellij.AuroraParserDefinition"/>

        <!-- Token-level syntax highlighting (active before LSP starts) -->
        <lang.syntaxHighlighterFactory
                language="aurora"
                implementationClass="aurora.intellij.AuroraSyntaxHighlighterFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <!-- Aurora Language Server -->
        <server id="AuroraLsp"
                name="Aurora Language Server"
                factoryClass="aurora.intellij.AuroraLspServerFactory"/>
        <languageMapping
                language="aurora"
                serverId="AuroraLsp"/>
    </extensions>
</idea-plugin>