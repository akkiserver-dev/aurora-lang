namespace Aurora

pub class Io {
    local static native fun __native_io_print(msg: object) -> void
    local static native fun __native_io_println(msg: object) -> void
    local static native fun __native_io_readLine() -> string?

    pub static fun print(msg: object) -> void => __native_io_print(msg)

    pub static fun println(msg: object) -> void => __native_io_println(msg)

    pub static fun readLine() -> string? => __native_io_readLine()
}